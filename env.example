# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_name   # or numeric ID like -1001234567890

# ─── Delta Exchange ─────────────────────────────────────────
# Public API — no key needed for market data reads
DELTA_BASE_URL=https://api.india.delta.exchange

# ─── Bot behaviour ──────────────────────────────────────────
# Timezone for all scheduling
TZ=Asia/Kolkata

# Entry window (IST, 24h)
ENTRY_WINDOW_START=11
ENTRY_WINDOW_END=13

# Hard exit time (IST)
HARD_EXIT_HOUR=16
HARD_EXIT_MINUTE=30

# Post-entry monitoring interval in minutes
MONITOR_INTERVAL_MINUTES=10

# Hourly scan interval (minutes) outside entry window
HOURLY_SCAN_MINUTES=60
