# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_name   # or numeric ID like -1001234567890

# ─── Delta Exchange ─────────────────────────────────────────
# Public API — no key needed for market data reads
DELTA_BASE_URL=https://api.india.delta.exchange

# Private API — required for autonomous order execution
DELTA_API_KEY=your_api_key_here
DELTA_API_SECRET=your_api_secret_here

# ─── Position sizing ─────────────────────────────────────────
POSITION_CONTRACTS=100        # full-size (1 BTC = 1000 contracts)
HALF_SIZE_CONTRACTS=50        # used for 2/4 B-score (LOW confidence) trades

# ─── Safety ──────────────────────────────────────────────────
PAPER_TRADE=true              # set false only when ready to go live

# ─── Bot behaviour ──────────────────────────────────────────
# Timezone for all scheduling
TZ=Asia/Kolkata

# Entry window (IST, 24h)
ENTRY_WINDOW_START=11
ENTRY_WINDOW_END=13

# Hard exit time (IST)
HARD_EXIT_HOUR=16
HARD_EXIT_MINUTE=30

# How often to scan for opportunities (minutes) — runs 24/7
SCAN_INTERVAL_MINUTES=5

# Which expiry tenors to hunt: "daily", "weekly", "monthly", or "all"
# Comma-separated, e.g. "daily,weekly" (default)
CONTRACT_TENORS=daily,weekly

# Post-entry monitoring interval in minutes (1 = every minute while in a trade)
MONITOR_INTERVAL_MINUTES=1
